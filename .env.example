# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: enable AI conversation tone
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Optional: payOS payment link and payment verification
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=https://casso-entry-test.onrender.com/payment-success
PAYOS_CANCEL_URL=https://casso-entry-test.onrender.com/payment-cancel

# Optional: generate VietQR transfer link at checkout
BANK_CODE=your_bank_code
BANK_ACCOUNT=your_bank_account_number
BANK_ACCOUNT_NAME=your_bank_account_name

# Optional: set when deploying as a webhook web service
WEBHOOK_HOST=https://casso-entry-test.onrender.com

# Note: Render does not read your local .env file.
# Set these values in Render dashboard -> Environment and redeploy.
